{
  "name": "modern-fullstack-react-projects-back-end",
  "private": true,
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist/**/*.js"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile",
    "compile": "tsc",
    "clean": "rm -r dist",
    "dev": "tsx --env-file=.env --watch src/server.ts",
    "init:db": "docker compose up",
    "lint": "eslint .",
    "format": "eslint --fix .",
    "start": "node --env-file=.env dist/server.js",
    "test": "vitest"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mongodb": "^6.18.0",
    "mongoose": "^8.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "mongodb-memory-server": "^10.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "**/*.js": [
      "npx lint --fix"
    ]
  }
}
